# Obligatoria para el cliente.
#
# back-security (WebFlux): base-path /security-auth en el JAR (puerto 8081).
# En local con Vite, el proxy reescribe /security-api → /security-auth en 127.0.0.1:8081.
VITE_SECURITY_URL=/security-api
#
# Sin proxy (navegador → JAR directo; el security debe permitir CORS o usar mismo origen vía gateway):
# VITE_SECURITY_URL=http://127.0.0.1:8081/security-auth
#
# Recomendado en local (npm run dev): URL directa al backend — la ingesta (POST /vector/ingest)
# puede tardar minutos sin enviar bytes; algunos proxies cortan ese caso. CORS ya permite localhost.
# Backend con context-path /docviz: el proxy de Vite reescribe /api → /docviz en 127.0.0.1:8080.
VITE_API_URL=/api
#
# Sin proxy (navegador llama al JAR directamente):
# VITE_API_URL=http://127.0.0.1:8080/docviz
# - docker-compose (imagen frontend): http://127.0.0.1:8080/docviz
# - Railway / prod: https://tu-backend.up.railway.app
#
# Markdown de soporte (S3 LocalStack + pgvector): el backend debe tener DOCVIZ_SUPPORT_ENABLED=true
# (p. ej. docker-compose). Si está en false, la UI sigue guardando soporte solo en localStorage.
