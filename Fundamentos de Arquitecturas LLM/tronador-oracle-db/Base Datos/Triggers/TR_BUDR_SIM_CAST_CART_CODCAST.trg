CREATE OR REPLACE TRIGGER TR_BUDR_SIM_CAST_CART_CODCAST
/*
    Modifico : Rolphy Quintero - Asesoftware - Germ·n MuÒoz
    fecha :  Agosto 24 de 2015 - Mantis 38430 - Proyecto Castigo de Cartera
    Desc : CreaciÛn del trigger. Auditar tabla SIM_CAST_CARTERA_COD_CASTIGO.
*/
  BEFORE UPDATE OR DELETE ON SIM_CAST_CARTERA_COD_CASTIGO FOR EACH ROW
Declare
  vl_Tipo_Operacion  SIM_HISTORIAL_CASTCART_CODCAST.Tipo_Operacion%type;
Begin
  If Updating Then
    vl_Tipo_Operacion := 'A'; -- ActualizaciÛn
    INSERT INTO SIM_HISTORIAL_CASTCART_CODCAST (SECUENCIA, ROWID_CASTCART_COD_CASTIGO, FECHA_CREACION_REGISTRO, TIPO_OPERACION,
    COD_CASTIGO, DESCRIPCION, ESTADO, FECHA_CREACION, USUARIO_CREACION, FECHA_MODIFICACION, USUARIO_MODIFICACION)
    VALUES (SEQ_HISTORIAL_CASTCART_CODCAST.NEXTVAL, :NEW.ROWID, SYSDATE, vl_Tipo_Operacion,
    :NEW.COD_CASTIGO, :NEW.DESCRIPCION, :NEW.ESTADO, :NEW.FECHA_CREACION, :NEW.USUARIO_CREACION, :NEW.FECHA_MODIFICACION, :NEW.USUARIO_MODIFICACION);
  Elsif Deleting Then
    vl_Tipo_Operacion := 'B'; -- Borrado
    INSERT INTO SIM_HISTORIAL_CASTCART_CODCAST (SECUENCIA, ROWID_CASTCART_COD_CASTIGO, FECHA_CREACION_REGISTRO, TIPO_OPERACION,
    COD_CASTIGO, DESCRIPCION, ESTADO, FECHA_CREACION, USUARIO_CREACION, FECHA_MODIFICACION, USUARIO_MODIFICACION)
    VALUES (SEQ_HISTORIAL_CASTCART_CODCAST.NEXTVAL, :OLD.ROWID, SYSDATE, vl_Tipo_Operacion,
    :OLD.COD_CASTIGO, :OLD.DESCRIPCION, :OLD.ESTADO, :OLD.FECHA_CREACION, :OLD.USUARIO_CREACION, :OLD.FECHA_MODIFICACION, :OLD.USUARIO_MODIFICACION);
  End If;
End TR_BUDR_SIM_CAST_CART_CODCAST;
/
