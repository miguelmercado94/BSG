CREATE OR REPLACE TRIGGER TRG_HIST_EMI_BLOQUE_MEDICO
AFTER INSERT OR UPDATE ON EMI_BLOQUE_MEDICO
FOR EACH ROW
DECLARE

BEGIN
   INSERT INTO EMI_HISTORICO_BLOQUE_MEDICO
         (NUMERO_SOLICITUD,
          CODIGO_RIESGO,
		  PESO_ACTUAL,
		  ESTATURA,
		  INDICE_MASA_CORPORAL,
		  HIPERTENSION_ARTERIAL,
		  COLESTEROL_TRIGLICERIDOS,
		  OBESIDAD,
		  ESTA_EMBARAZADA,
		  OTRA_ENFERMEDAD_SINTOMA,
		  CUAL_ENFERMEDAD,
		  DEBE_TRAER_HISTORIA_CLINICA,
		  PARALISIS_O_AMPUTACIONES,
		  CIRUGIAS,
		  SUSTANCIAS_ADICTIVAS,
		  SUSTANCIA_TOXICA,
		  FUMA,
		  FUMABA,
		  HACE_CUANTO,
		  CUANTOS_CIGARRILLOS,
		  TOMA_ALGUN_MEDICAMENTO,
		  POR_ENFERMEDAD_MENCIONADA,
		  OTRO_MEDICAMENTO,
		  CUAL_MEDICAMENTO,
		  CIRUGIA_PROGRAMADA,
		  CUAL_CIRUGIA,
		  ESTUDIO_HTA,
		  ESTUDIO_OBESIDAD,
		  ESTUDIO_LIPIDOS,
		  ESTUDIO_DIABETES,
		  SE_ENVIA_A_EVALUACION,
		  USUARIO_CREACION,
		  FECHA_CREACION,
		  USUARIO_TRANSACCION,
		  FECHA_TRANSACCION
		 )
   VALUES(:NEW.NUMERO_SOLICITUD,
          :NEW.CODIGO_RIESGO,
		  :NEW.PESO_ACTUAL,
		  :NEW.ESTATURA,
		  :NEW.INDICE_MASA_CORPORAL,
		  :NEW.HIPERTENSION_ARTERIAL,
		  :NEW.COLESTEROL_TRIGLICERIDOS,
		  :NEW.OBESIDAD,
		  :NEW.ESTA_EMBARAZADA,
		  :NEW.OTRA_ENFERMEDAD_SINTOMA,
		  :NEW.CUAL_ENFERMEDAD,
		  :NEW.DEBE_TRAER_HISTORIA_CLINICA,
		  :NEW.PARALISIS_O_AMPUTACIONES,
		  :NEW.CIRUGIAS,
		  :NEW.SUSTANCIAS_ADICTIVAS,
		  :NEW.SUSTANCIA_TOXICA,
		  :NEW.FUMA,
		  :NEW.FUMABA,
		  :NEW.HACE_CUANTO,
		  :NEW.CUANTOS_CIGARRILLOS,
		  :NEW.TOMA_ALGUN_MEDICAMENTO,
		  :NEW.POR_ENFERMEDAD_MENCIONADA,
		  :NEW.OTRO_MEDICAMENTO,
		  :NEW.CUAL_MEDICAMENTO,
		  :NEW.CIRUGIA_PROGRAMADA,
		  :NEW.CUAL_CIRUGIA,
		  :NEW.ESTUDIO_HTA,
		  :NEW.ESTUDIO_OBESIDAD,
		  :NEW.ESTUDIO_LIPIDOS,
		  :NEW.ESTUDIO_DIABETES,
		  :NEW.SE_ENVIA_A_EVALUACION,
		  :NEW.USUARIO_CREACION,
		  :NEW.FECHA_CREACION,
		  :NEW.USUARIO_TRANSACCION,
		  :NEW.FECHA_TRANSACCION
         );
END;
/
