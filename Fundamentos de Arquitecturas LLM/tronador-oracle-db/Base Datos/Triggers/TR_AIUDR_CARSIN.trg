CREATE OR REPLACE TRIGGER TR_AIUDR_CARSIN
   /*
      <Creacion>
      <Autor>Carlos Eduardo Mayorga</Autor>
      <Fecha>14/09/2016</Fecha>
      <Objetivo>Enviar la informacion a la tabla de auditoria</Objetivo>
     </Creacion>
    */
   AFTER INSERT OR UPDATE OR DELETE
   ON SIM_CARGA_SINIESTROS
   FOR EACH ROW
DECLARE
   l_operacion   VARCHAR2 (3);
BEGIN
   IF INSERTING
   THEN
      INSERT INTO SIM_CARGA_SINIESTROS_JN (JN_SECUENCIA,
                                           JN_OPERACION,
                                           JN_ORACLE_USER,
                                           JN_DATETIME,
                                           SECUENCIA,
                                           PROCESO,
                                           ENT_COLOCADORA,
                                           SISTEMA_ORIGEN,
                                           COD_CIA,
                                           COD_SECC,
                                           COD_RAMO,
                                           NUM_POL1,
                                           POL_PRINCIPAL,
                                           FECHA_SINI,
                                           HORA_SINI,
                                           FECHA_DENU_SINI,
                                           COD_CAUSA_SINI,
                                           TDOC_TERCERO_TOM,
                                           NDOC_TERCERO_TOM,
                                           TDOC_TERCERO_ASEG,
                                           COD_RIES,
                                           DESC_SINI,
                                           FECHA_FORMALIZAC,
                                           MCA_MAS_POLIZ,
                                           TIPO_DEC,
                                           COD_USER,
                                           LONGITUD,
                                           LATITUD,
                                           ALTITUD,
                                           NUM_SINI,
                                           COD_CAUSA_MODI,
                                           FECHA_MODI,
                                           COD_CAUSA_BAJA,
                                           FECHA_BAJA,
                                           COD_CAUSA_REAP,
                                           FECHA_REAPERTURA,
                                           ESTADO_SINIESTRO,
                                           SIM_USUARIO,
                                           MCA_PROCESO,
                                           FECHA_PROCESO,
                                           MCA_PROCESO_TER,
                                           FECHA_PROCESO_TER,
                                           USUARIO_CREACION,
                                           FECHA_CREACION,
                                           USUARIO_MODIFICACION,
                                           FECHA_MODIFICACION)
           VALUES (SEQ_SIM_CAR_SINI_JN.NEXTVAL,
                   'INS',
                   USER,
                   SYSDATE,
                   :NEW.SECUENCIA,
                   :NEW.PROCESO,
                   :NEW.ENT_COLOCADORA,
                   :NEW.SISTEMA_ORIGEN,
                   :NEW.COD_CIA,
                   :NEW.COD_SECC,
                   :NEW.COD_RAMO,
                   :NEW.NUM_POL1,
                   :NEW.POL_PRINCIPAL,
                   :NEW.FECHA_SINI,
                   :NEW.HORA_SINI,
                   :NEW.FECHA_DENU_SINI,
                   :NEW.COD_CAUSA_SINI,
                   :NEW.TDOC_TERCERO_TOM,
                   :NEW.NDOC_TERCERO_TOM,
                   :NEW.TDOC_TERCERO_ASEG,
                   :NEW.COD_RIES,
                   :NEW.DESC_SINI,
                   :NEW.FECHA_FORMALIZAC,
                   :NEW.MCA_MAS_POLIZ,
                   :NEW.TIPO_DEC,
                   :NEW.COD_USER,
                   :NEW.LONGITUD,
                   :NEW.LATITUD,
                   :NEW.ALTITUD,
                   :NEW.NUM_SINI,
                   :NEW.COD_CAUSA_MODI,
                   :NEW.FECHA_MODI,
                   :NEW.COD_CAUSA_BAJA,
                   :NEW.FECHA_BAJA,
                   :NEW.COD_CAUSA_REAP,
                   :NEW.FECHA_REAPERTURA,
                   :NEW.ESTADO_SINIESTRO,
                   :NEW.SIM_USUARIO,
                   :NEW.MCA_PROCESO,
                   :NEW.FECHA_PROCESO,
                   :NEW.MCA_PROCESO_TER,
                   :NEW.FECHA_PROCESO_TER,
                   :NEW.USUARIO_CREACION,
                   :NEW.FECHA_CREACION,
                   :NEW.USUARIO_MODIFICACION,
                   :NEW.FECHA_MODIFICACION);
   ELSE
      IF UPDATING
      THEN
         l_operacion := 'UPD';
      ELSIF DELETING
      THEN
         l_operacion := 'DEL';
      END IF;

      INSERT INTO SIM_CARGA_SINIESTROS_JN (JN_SECUENCIA,
                                           JN_OPERACION,
                                           JN_ORACLE_USER,
                                           JN_DATETIME,
                                           SECUENCIA,
                                           PROCESO,
                                           ENT_COLOCADORA,
                                           SISTEMA_ORIGEN,
                                           COD_CIA,
                                           COD_SECC,
                                           COD_RAMO,
                                           NUM_POL1,
                                           POL_PRINCIPAL,
                                           FECHA_SINI,
                                           HORA_SINI,
                                           FECHA_DENU_SINI,
                                           COD_CAUSA_SINI,
                                           TDOC_TERCERO_TOM,
                                           NDOC_TERCERO_TOM,
                                           TDOC_TERCERO_ASEG,
                                           COD_RIES,
                                           DESC_SINI,
                                           FECHA_FORMALIZAC,
                                           MCA_MAS_POLIZ,
                                           TIPO_DEC,
                                           COD_USER,
                                           LONGITUD,
                                           LATITUD,
                                           ALTITUD,
                                           NUM_SINI,
                                           COD_CAUSA_MODI,
                                           FECHA_MODI,
                                           COD_CAUSA_BAJA,
                                           FECHA_BAJA,
                                           COD_CAUSA_REAP,
                                           FECHA_REAPERTURA,
                                           ESTADO_SINIESTRO,
                                           SIM_USUARIO,
                                           MCA_PROCESO,
                                           FECHA_PROCESO,
                                           MCA_PROCESO_TER,
                                           FECHA_PROCESO_TER,
                                           USUARIO_CREACION,
                                           FECHA_CREACION,
                                           USUARIO_MODIFICACION,
                                           FECHA_MODIFICACION)
           VALUES (SEQ_SIM_CAR_SINI_JN.NEXTVAL,
                   l_operacion,
                   USER,
                   SYSDATE,
                   :OLD.SECUENCIA,
                   :OLD.PROCESO,
                   :OLD.ENT_COLOCADORA,
                   :OLD.SISTEMA_ORIGEN,
                   :OLD.COD_CIA,
                   :OLD.COD_SECC,
                   :OLD.COD_RAMO,
                   :OLD.NUM_POL1,
                   :OLD.POL_PRINCIPAL,
                   :OLD.FECHA_SINI,
                   :OLD.HORA_SINI,
                   :OLD.FECHA_DENU_SINI,
                   :OLD.COD_CAUSA_SINI,
                   :OLD.TDOC_TERCERO_TOM,
                   :OLD.NDOC_TERCERO_TOM,
                   :OLD.TDOC_TERCERO_ASEG,
                   :OLD.COD_RIES,
                   :OLD.DESC_SINI,
                   :OLD.FECHA_FORMALIZAC,
                   :OLD.MCA_MAS_POLIZ,
                   :OLD.TIPO_DEC,
                   :OLD.COD_USER,
                   :OLD.LONGITUD,
                   :OLD.LATITUD,
                   :OLD.ALTITUD,
                   :OLD.NUM_SINI,
                   :OLD.COD_CAUSA_MODI,
                   :OLD.FECHA_MODI,
                   :OLD.COD_CAUSA_BAJA,
                   :OLD.FECHA_BAJA,
                   :OLD.COD_CAUSA_REAP,
                   :OLD.FECHA_REAPERTURA,
                   :OLD.ESTADO_SINIESTRO,
                   :OLD.SIM_USUARIO,
                   :OLD.MCA_PROCESO,
                   :OLD.FECHA_PROCESO,
                   :OLD.MCA_PROCESO_TER,
                   :OLD.FECHA_PROCESO_TER,
                   :OLD.USUARIO_CREACION,
                   :OLD.FECHA_CREACION,
                   :OLD.USUARIO_MODIFICACION,
                   :OLD.FECHA_MODIFICACION);
   END IF;
END TR_AIUDR_CARSIN;
/
