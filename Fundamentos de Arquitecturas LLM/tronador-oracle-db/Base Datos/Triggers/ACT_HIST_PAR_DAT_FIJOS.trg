CREATE OR REPLACE TRIGGER ACT_HIST_PAR_DAT_FIJOS
AFTER
--	INSERT OR
	UPDATE OR
	DELETE
	ON C1990001
FOR EACH ROW
DECLARE
	mi_contador						NUMBER;
	mi_cod_error					C2990999.COD_ERROR%TYPE := 0;
	mi_error_mensaje			C2990999.ERROR_MENSAJE%TYPE := 'N/A';
	mi_error_real					C2990999.ERROR_REAL%TYPE := 'N/A';
BEGIN		
	IF UPDATING THEN

		--Llamado a la Insercion del Historico de Parametrizacion de Datos Fijos
		PCK299_VALIDA_BANCA.PRC_CARG_DATOS_PAR_DAT_FIJ_H-- C1990001_H
		(
			P_COD_CIA =>
				:OLD.COD_CIA,
			P_COD_SECC =>
				:OLD.COD_SECC,
			P_COD_RAMO =>
				:OLD.COD_RAMO,
			P_SUB_PRODUCTO =>
				:OLD.SUB_PRODUCTO,
			P_ENTIDAD_COLOCADORA =>
				:OLD.ENTIDAD_COLOCADORA,
			P_POL_PPAL =>
				:OLD.POL_PPAL,
			P_NUM_POL_FLOT =>
