			P_COD_ENTIDAD_DEF =>
				:OLD.COD_ENTIDAD_DEF,
			P_CANAL_DESCTO_UNICA =>
				:OLD.CANAL_DESCTO_UNICA,
			P_CANAL_DESCTO_HEREDA =>
				:OLD.CANAL_DESCTO_HEREDA,
			P_CANAL_DESCTO_VALIDA =>
				:OLD.CANAL_DESCTO_VALIDA,
			P_CANAL_DESCTO_DEF =>
				:OLD.CANAL_DESCTO_DEF,
			P_TOMADOR_UNICO =>
				:OLD.TOMADOR_UNICO,
			P_TOMADOR_HEREDA =>
				:OLD.TOMADOR_HEREDA,
			P_TDOC_TERCERO_VALIDA =>
