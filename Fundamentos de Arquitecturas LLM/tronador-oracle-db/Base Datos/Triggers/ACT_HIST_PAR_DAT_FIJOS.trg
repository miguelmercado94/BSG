			P_PER_FACT_UNICO =>
				:OLD.PER_FACT_UNICO,
			P_PER_FACT_HEREDA =>
				:OLD.PER_FACT_HEREDA,
			P_PER_FACT_VALIDA =>
				:OLD.PER_FACT_VALIDA,
			P_PER_FAC_DEF =>
