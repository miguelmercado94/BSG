--				:OLD.VENC_UNIF_DEF,
			P_COD_COA_UNICA =>
				:OLD.COD_COA_UNICA,
			P_COD_COA_HEREDA =>
				:OLD.COD_COA_HEREDA,
			P_COD_COA_VALIDA =>
				:OLD.COD_COA_VALIDA,
			P_COD_COA_DEF =>
				:OLD.COD_COA_DEF,
			P_COD_CIACOA_DEF =>
				:OLD.COD_CIACOA_DEF,
			P_NUM_POL_COA_DEF =>
				:OLD.NUM_POL_COA_DEF,
			P_NUM_ENDOSO_COA_DEF =>
				:OLD.NUM_ENDOSO_COA_DEF,
