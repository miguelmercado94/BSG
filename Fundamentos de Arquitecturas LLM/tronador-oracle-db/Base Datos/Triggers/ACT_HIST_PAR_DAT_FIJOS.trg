			P_COD_COB_NOMINA =>
				:OLD.COD_COB_NOMINA,
			P_USUARIO_CREACION =>
				:OLD.USUARIO_CREACION,
			P_FECHA_CREACION =>
				:OLD.FECHA_CREACION,
			P_USUARIO_MODIFICACION =>
				:OLD.USUARIO_MODIFICACION,
			P_FECHA_MODIFICACION =>
				:OLD.FECHA_MODIFICACION,
			P_TIPO_OPERACION =>
				'U',
			P_USUARIO_ACTUALIZACION =>
				SUBSTR(REPLACE(USER,'$',''),4,8),
			P_FECHA_ACTUALIZACION =>
				SYSDATE,
			P_COD_ERROR =>
				mi_cod_error,
			P_ERROR_MENSAJE =>
				mi_error_mensaje,
			P_ERROR_REAL =>
				mi_error_real
		);

	ELSIF DELETING THEN

		--Llamado a la Insercion del Historico de Parametrizacion de Datos Fijos
		PCK299_VALIDA_BANCA.PRC_CARG_DATOS_PAR_DAT_FIJ_H-- C1990001_H
		(
			P_COD_CIA =>
				:OLD.COD_CIA,
			P_COD_SECC =>
				:OLD.COD_SECC,
			P_COD_RAMO =>
				:OLD.COD_RAMO,
			P_SUB_PRODUCTO =>
				:OLD.SUB_PRODUCTO,
			P_ENTIDAD_COLOCADORA =>
				:OLD.ENTIDAD_COLOCADORA,
			P_POL_PPAL =>
				:OLD.POL_PPAL,
			P_NUM_POL_FLOT =>
