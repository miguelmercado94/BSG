			P_COD_ERROR =>
				mi_cod_error,
			P_ERROR_MENSAJE =>
				mi_error_mensaje,
			P_ERROR_REAL =>
				mi_error_real
		);

	END IF;
END act_hist_par_dat_fijos;
/
