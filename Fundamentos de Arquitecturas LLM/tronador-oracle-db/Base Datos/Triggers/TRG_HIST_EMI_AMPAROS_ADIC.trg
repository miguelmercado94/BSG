CREATE OR REPLACE TRIGGER TRG_HIST_EMI_AMPAROS_ADIC
AFTER INSERT OR UPDATE ON EMI_AMPAROS_ADICIONALES
FOR EACH ROW
DECLARE

BEGIN
   INSERT INTO EMI_HISTORICO_AMPAROS_ADIC
         (NUMERO_SOLICITUD,
		  CODIGO_RIESGO,
		  VIDA_RIESGO,
		  DESMEMBRACION,
		  SUMA_DESMEMBRACION,
		  RENTA_MENSUAL_INCAPACIDAD,
		  SUMA_RENTA_MENSUAL_INCAPACIDAD,
		  GASTOS_MEDICOS,
		  SUMA_GASTOS_MEDICOS,
		  ENF_GRAVES_ANTIC_40,
		  SUMA_ENF_GRAVES_ANTIC_40,
		  INCAPACIDAD_TOTAL_PERMANENTE,
		  SUMA_ITP,
		  ENF_GRAVES_ANTIC_40_EXCL,
		  SUMA_ENF_GRAVES_ANTIC_40_EXCL,
		  ENF_GRAVES_ADIC_100,
		  SUMA_ENF_GRAVES_ADIC_100,
		  ENF_GRAVES_ADIC_100_EXCL,
		  SUMA_ENF_GRAVES_ADIC_100_EXCL,
		  EXONERACION_DE_PRIMAS,
		  TOTAL_PRIMA_DE_RIESGO,
		  OPCION_ASEG,
		  USUARIO_CREACION,
		  FECHA_CREACION,
		  USUARIO_TRANSACCION,
		  FECHA_TRANSACCION
		 )
   VALUES(:NEW.NUMERO_SOLICITUD,
          :NEW.CODIGO_RIESGO,
		  :NEW.VIDA_RIESGO,
		  :NEW.DESMEMBRACION,
		  :NEW.SUMA_DESMEMBRACION,
		  :NEW.RENTA_MENSUAL_INCAPACIDAD,
		  :NEW.SUMA_RENTA_MENSUAL_INCAPACIDAD,
		  :NEW.GASTOS_MEDICOS,
		  :NEW.SUMA_GASTOS_MEDICOS,
		  :NEW.ENF_GRAVES_ANTIC_40,
		  :NEW.SUMA_ENF_GRAVES_ANTIC_40,
		  :NEW.INCAPACIDAD_TOTAL_PERMANENTE,
		  :NEW.SUMA_ITP,
		  :NEW.ENF_GRAVES_ANTIC_40_EXCL,
		  :NEW.SUMA_ENF_GRAVES_ANTIC_40_EXCL,
		  :NEW.ENF_GRAVES_ADIC_100,
		  :NEW.SUMA_ENF_GRAVES_ADIC_100,
		  :NEW.ENF_GRAVES_ADIC_100_EXCL,
		  :NEW.SUMA_ENF_GRAVES_ADIC_100_EXCL,
		  :NEW.EXONERACION_DE_PRIMAS,
		  :NEW.TOTAL_PRIMA_DE_RIESGO,
		  :NEW.OPCION_ASEG,
		  :NEW.USUARIO_CREACION,
		  :NEW.FECHA_CREACION,
		  :NEW.USUARIO_TRANSACCION,
		  :NEW.FECHA_TRANSACCION
         );
END;
/
