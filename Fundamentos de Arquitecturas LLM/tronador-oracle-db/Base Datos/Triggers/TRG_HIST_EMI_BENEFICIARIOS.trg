CREATE OR REPLACE TRIGGER TRG_HIST_EMI_BENEFICIARIOS
AFTER INSERT OR UPDATE ON EMI_BENEFICIARIOS
FOR EACH ROW
DECLARE

BEGIN
   INSERT INTO EMI_HISTORICO_BENEFICIARIOS
         (NUMERO_SOLICITUD,
 		  CODIGO_RIESGO,
		  CONSECUTIVO,
		  TIPDOC_CODIGO,
		  NUMERO_DOCUMENTO,
		  PRIMER_NOMBRE,
		  SEGUNDO_NOMBRE,
		  PRIMER_APELLIDO,
		  SEGUNDO_APELLIDO,
		  PARENTESCO,
		  CALIDAD,
		  PORCENTAJE_PARTICIPACION,
		  USUARIO_CREACION,
		  FECHA_CREACION,
		  USUARIO_TRANSACCION,
		  FECHA_TRANSACCION,
		  COSTO_EDUCATIVO_MENSUAL,
		  ANOS_PENDIENTE_SECUN,
		  COSTO_SEMESTRE_ACTUAL,
		  ANOS_PROY_UNIV,
		  GASTOS_EDUCATIVOS,
		  PAGO_TOTAL,
		  RENTA_MENSUAL,
		  ANOS_PAGO
		 )
   VALUES(:NEW.NUMERO_SOLICITUD,
          :NEW.CODIGO_RIESGO,
		  :NEW.CONSECUTIVO,
		  :NEW.TIPDOC_CODIGO,
		  :NEW.NUMERO_DOCUMENTO,
		  :NEW.PRIMER_NOMBRE,
		  :NEW.SEGUNDO_NOMBRE,
		  :NEW.PRIMER_APELLIDO,
		  :NEW.SEGUNDO_APELLIDO,
		  :NEW.PARENTESCO,
		  :NEW.CALIDAD,
		  :NEW.PORCENTAJE_PARTICIPACION,
		  :NEW.USUARIO_CREACION,
		  :NEW.FECHA_CREACION,
		  :NEW.USUARIO_TRANSACCION,
		  :NEW.FECHA_TRANSACCION,
		  :NEW.COSTO_EDUCATIVO_MENSUAL,
		  :NEW.ANOS_PENDIENTE_SECUN,
		  :NEW.COSTO_SEMESTRE_ACTUAL,
		  :NEW.ANOS_PROY_UNIV,
		  :NEW.GASTOS_EDUCATIVOS,
		  :NEW.PAGO_TOTAL,
		  :NEW.RENTA_MENSUAL,
		  :NEW.ANOS_PAGO
         );
END;
/
