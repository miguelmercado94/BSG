CREATE OR REPLACE TRIGGER TRG_HIST_EMI_CONCEPTO_TECNICO
AFTER INSERT OR UPDATE ON EMI_CONCEPTO_TECNICO
FOR EACH ROW
DECLARE

BEGIN
   INSERT INTO EMI_HISTORICO_CONCEPTO_TECNICO
         (NUMERO_SOLICITUD,
		  CODIGO_RIESGO,
		  TIPO_RIES,
		  TIPO_RIES_RE,
		  REC_OCU_VIDA,
		  REC_SALU_VIDA,
		  PORC_DESADMTVO,
		  REC_X_MUERTE,
		  PORC_DESADM902,
		  REC_X_DESMEM,
		  PORC_DESADM903,
		  REC_X_INDEMN,
		  PORC_DESADM904,
		  REC_X_GASMED,
		  PORC_DESADM905,
		  REC_SALU_EG,
		  PORC_DESADM906,
		  REC_SALU_ITP,
		  PORC_DESADM908,
		  REC_SALU_EE,
		  PORC_DESADM910,
		  REC_SALU_EADIC,
		  PORC_DESADM911,
		  REC_SALU_EEADI,
		  PORC_DESADM912,
		  CAMBIA_A_PREFERENTE,
		  CATEGORIA,
		  USUARIO_CREACION,
		  FECHA_CREACION,
		  USUARIO_TRANSACCION,
		  FECHA_TRANSACCION
		 )
   VALUES(:NEW.NUMERO_SOLICITUD,
          :NEW.CODIGO_RIESGO,
		  :NEW.TIPO_RIES,
		  :NEW.TIPO_RIES_RE,
		  :NEW.REC_OCU_VIDA,
		  :NEW.REC_SALU_VIDA,
		  :NEW.PORC_DESADMTVO,
		  :NEW.REC_X_MUERTE,
		  :NEW.PORC_DESADM902,
		  :NEW.REC_X_DESMEM,
		  :NEW.PORC_DESADM903,
		  :NEW.REC_X_INDEMN,
		  :NEW.PORC_DESADM904,
		  :NEW.REC_X_GASMED,
		  :NEW.PORC_DESADM905,
		  :NEW.REC_SALU_EG,
		  :NEW.PORC_DESADM906,
		  :NEW.REC_SALU_ITP,
		  :NEW.PORC_DESADM908,
		  :NEW.REC_SALU_EE,
		  :NEW.PORC_DESADM910,
		  :NEW.REC_SALU_EADIC,
		  :NEW.PORC_DESADM911,
		  :NEW.REC_SALU_EEADI,
		  :NEW.PORC_DESADM912,
		  :NEW.CAMBIA_A_PREFERENTE,
		  :NEW.CATEGORIA,
		  :NEW.USUARIO_CREACION,
		  :NEW.FECHA_CREACION,
		  :NEW.USUARIO_TRANSACCION,
		  :NEW.FECHA_TRANSACCION
         );
END;
/
