CREATE OR REPLACE TRIGGER TRG_HIST_EMI_DATOS_ASEGURADO
AFTER INSERT OR UPDATE ON EMI_DATOS_ASEGURADO FOR EACH ROW
DECLARE

BEGIN
   INSERT INTO EMI_HISTORICO_DATOS_ASEGURADO
         (NUMERO_SOLICITUD,
		  CODIGO_RIESGO,
		  ENTIDAD_SEGURIDAD_SOCIAL,
		  ES_ZURDO,
		  NIVEL_DE_EDUCACION,
		  VIDA_PROTEGIDA,
          INDEMNIZACION_PREVIA,
		  LICENCIA_PILOTO,
		  MANEJA_MOTOCICLETA,
		  DEPORTES_ALTO_RIESGO,
		  PRACTICA_OTROS_DEPORTES,
		  CUALES_DEPORTES,
		  ACTIVIDADES_LICITAS,
		  CONDENADO_PENALMENTE,
		  SECUESTRADO,
		  RESIDE_EXTERIOR,
		  USUARIO_CREACION,
		  FECHA_CREACION,
		  USUARIO_TRANSACCION,
		  FECHA_TRANSACCION,
		  OTRO_DEPORTE_ALTO_RIESGO
		 )
   VALUES(:NEW.NUMERO_SOLICITUD,
          :NEW.CODIGO_RIESGO,
		  :NEW.ENTIDAD_SEGURIDAD_SOCIAL,
		  :NEW.ES_ZURDO,
		  :NEW.NIVEL_DE_EDUCACION,
		  :NEW.VIDA_PROTEGIDA,
          :NEW.INDEMNIZACION_PREVIA,
		  :NEW.LICENCIA_PILOTO,
		  :NEW.MANEJA_MOTOCICLETA,
		  :NEW.DEPORTES_ALTO_RIESGO,
		  :NEW.PRACTICA_OTROS_DEPORTES,
		  :NEW.CUALES_DEPORTES,
		  :NEW.ACTIVIDADES_LICITAS,
		  :NEW.CONDENADO_PENALMENTE,
		  :NEW.SECUESTRADO,
		  :NEW.RESIDE_EXTERIOR,
		  :NEW.USUARIO_CREACION,
		  :NEW.FECHA_CREACION,
		  :NEW.USUARIO_TRANSACCION,
		  :NEW.FECHA_TRANSACCION,
		  :NEW.OTRO_DEPORTE_ALTO_RIESGO
         );
END;
/
