CREATE OR REPLACE TRIGGER TRG_HIST_EMI_FORMA_PAGO
AFTER INSERT OR UPDATE ON EMI_FORMA_PAGO
FOR EACH ROW
DECLARE

BEGIN
   INSERT INTO EMI_HISTORICO_FORMA_PAGO
         (NUMERO_SOLICITUD,
          PRIMERA_CUOTA_EFECTIVO,
		  FORMA_PAGO,
		  NIT_LIBRANZA,
		  ENTIDAD_DEBITO,
		  COD_IDENTIF,
		  TIPO_CUENTA,
		  NUMERO_CUENTA,
		  FECHA_VCTO_TARJETA,
		  NOMBRE_CTAHABIENTE,
		  IDENTIFICACION_CTAHABIENTE,
		  DIRECCION_CTAHABIENTE,
		  CIUDAD_CTAHABIENTE,
		  TELEFONO_CTAHABIENTE,
		  USUARIO_CREACION,
		  FECHA_CREACION,
		  USUARIO_TRANSACCION,
		  FECHA_TRANSACCION,
		  TIPO_DOC_LIBRANZA,
		  PERIODICIDAD,
		  VALOR_A_AHORRAR,
		  INC_ANUAL_AHORRO,
		  TOTAL_PRIMA_MAS_AHORRO,
		  INC_ADICIONAL_IPC_RENOVACION
		 )
   VALUES(:NEW.NUMERO_SOLICITUD,
          :NEW.PRIMERA_CUOTA_EFECTIVO,
		  :NEW.FORMA_PAGO,
		  :NEW.NIT_LIBRANZA,
		  :NEW.ENTIDAD_DEBITO,
		  :NEW.COD_IDENTIF,
		  :NEW.TIPO_CUENTA,
		  :NEW.NUMERO_CUENTA,
		  :NEW.FECHA_VCTO_TARJETA,
		  :NEW.NOMBRE_CTAHABIENTE,
		  :NEW.IDENTIFICACION_CTAHABIENTE,
		  :NEW.DIRECCION_CTAHABIENTE,
		  :NEW.CIUDAD_CTAHABIENTE,
		  :NEW.TELEFONO_CTAHABIENTE,
		  :NEW.USUARIO_CREACION,
		  :NEW.FECHA_CREACION,
		  :NEW.USUARIO_TRANSACCION,
		  :NEW.FECHA_TRANSACCION,
		  :NEW.TIPO_DOC_LIBRANZA,
		  :NEW.PERIODICIDAD,
		  :NEW.VALOR_A_AHORRAR,
		  :NEW.INC_ANUAL_AHORRO,
		  :NEW.TOTAL_PRIMA_MAS_AHORRO,
		  :NEW.INC_ADICIONAL_IPC_RENOVACION
         );
END;
/
