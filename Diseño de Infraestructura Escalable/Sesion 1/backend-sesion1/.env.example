# Copia a .env y rellena (DotenvEnvironmentPostProcessor carga .env al arrancar desde backend-sesion1)
#
# Maven puede usar JDK distinto al `java` del PATH. En Windows: define JAVA_HOME al JDK 21
# o ejecuta .\run-backend-local.ps1 (fuerza JDK 21 y mvn spring-boot:run).
#
# Desarrollo local típico: Ollama + PostgreSQL (pgvector) + Firestore
#   SPRING_PROFILES_ACTIVE=local
#   Maven: perfil "local" por defecto (ollama en el classpath)

SPRING_PROFILES_ACTIVE=local

# Prefijo de todas las rutas REST/WebSocket (alinear con module.path_base docviz en back-security-sesion1).
SERVER_SERVLET_CONTEXT_PATH=/docviz

# Clones HTTPS efímeros (context-masters/<usuario>/…). Si Git falla leyendo .git/objects/pack bajo OneDrive, usa ruta fija:
# DOCVIZ_CONTEXT_MASTERS_BASE_PATH=C:/docviz/context-masters

# Backend en el mismo PC que Ollama (Maven / JAR sin Docker):
OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# Docker Compose (carpeta Sesion 1): por defecto solo infra + Ollama + back-security; backend/frontend van en local.
# Para este .env con stack Docker: OLLAMA_BASE_URL=http://127.0.0.1:11434 (puerto publicado del contenedor ollama).
# Backend dentro de Compose con perfil "containerized": el servicio `ollama` usa OLLAMA_BASE_URL=http://ollama:11434.
# Si prefieres Ollama instalado en Windows: levanta Ollama en el host y en docker-compose.yml del backend pon
# OLLAMA_BASE_URL=http://host.docker.internal:11434 y extra_hosts: host.docker.internal:host-gateway
# Debe existir en Ollama (`ollama pull …`). Compose en Sesion 1 descarga por defecto llama3.2 (OLLAMA_PULL_CHAT); alternativa: qwen2.5:3b
OLLAMA_MODEL=llama3.2
# Ventana de contexto (tokens) en /api/chat; si el RAG + historial desborda: 8192–32768 según modelo.
OLLAMA_NUM_CTX=8192
# Tope de caracteres del bloque de chunks/menciones antes del historial (truncado si se pasa).
DOCVIZ_VECTOR_RAG_MAX_CONTEXT_CHARS=12000
OLLAMA_EMBED_MODEL=nomic-embed-text
# Ollama: el modelo de embeddings debe existir localmente o la API devuelve 404 "model not found".
#   ollama pull nomic-embed-text
# (Si cambias OLLAMA_EMBED_MODEL, alinea DOCVIZ_VECTOR_EMBEDDING_DIM con la dimensión del modelo.)

# Opcional: timeout async Spring para /vector/ingest/stream (por defecto 1h en application.properties)
# SPRING_MVC_ASYNC_REQUEST_TIMEOUT=2h

# Windows: rutas de archivo muy largas en el repo pueden fallar con "Filename too long" al indexar.
#   git config --global core.longpaths true
# y/o clonar en una ruta corta (p. ej. C:\work\repo).
#
# Docker Alpine: si el backend no encuentra `git` en PATH, fija el binario (docker-compose ya lo pone):
# DOCVIZ_CONTEXT_MASTERS_GIT_EXECUTABLE=/usr/bin/git

DATABASE_URL=jdbc:postgresql://localhost:5432/docviz
DATABASE_USER=docviz
DATABASE_PASSWORD=docviz
# Limpieza BD completa (dominio + vectores; desde carpeta Sesion 1): python scripts/clean_all_databases.py --yes
# Solo vectores: python backend-sesion1/scripts/pgvector_clear.py --list | --namespace NS | --all --yes
# Al arrancar el backend (sin perfil test) verás en logs: DocViz infra: PostgreSQL… y DocViz infra: Ollama…
# Prueba pipeline chunk→embed→pgvector: mvn test (Docker + imagen pgvector/pgvector:pg16; sin Docker el test se omite)
DOCVIZ_VECTOR_STORE=pgvector
DOCVIZ_VECTOR_EMBEDDING_DIM=768

# Opcional: al arrancar el main, clonar un repo público HTTPS y ejecutar la ingesta (mismo flujo que UI: connect + vector ingest)
# DOCVIZ_BOOTSTRAP_ENABLED=true
# DOCVIZ_BOOTSTRAP_GIT_URL=https://github.com/miguelmercado94/findu.git
# DOCVIZ_BOOTSTRAP_USER_ID=local-dev
# DOCVIZ_BOOTSTRAP_INGEST=true
# Embeddings: spring-ollama (por defecto) | pinecone-inference (solo si usas API Pinecone para embeds)
# DOCVIZ_EMBEDDINGS_PROVIDER=spring-ollama

# Firestore: historial RAG en users/{userIdSanitizado}/conversations/{conversationId}/messages
# (userId = cabecera X-DocViz-User, p. ej. soporte01 → documento "soporte01").
# El id de conversación incluye HU + tarea + hilo, p. ej. soporte01_Vehiculo_HU-002_3_0 (usuario_célula_hu_taskId_N).
# En la consola Firebase abre users → [tu usuario] → subcolección "conversations" (no solo "messages" a nivel raíz: eso es legado).
#
# Descarga JSON: Firebase Console → Proyecto → Cuentas de servicio → generar clave nueva.
# Maven/JAR en Windows: FIREBASE_ENABLED=true y ruta absoluta al .json en este PC.
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=sesion-bsg
FIREBASE_CREDENTIALS_PATH=C:/ruta/a/sesion-bsg-firebase-adminsdk-xxxxx.json
# GOOGLE_APPLICATION_CREDENTIALS=C:/ruta/a/sesion-bsg-firebase-adminsdk-xxxxx.json
#
# Docker Compose (backend en contenedor): la ruta del host (C:/...) NO existe dentro del Linux container.
# 1) Copia el JSON a la carpeta "Sesion 1" con el nombre esperado por docker-compose.yml
# 2) Descomenta en docker-compose.yml el volumen que monta ese archivo en /run/secrets/firebase-adminsdk.json
# 3) Arranca con FIREBASE_ENABLED=true (variable de entorno o .env en la raíz del compose)

# Opcional: cuántos turnos previos inyecta el backend en el prompt (Firestore).
# DOCVIZ_CHAT_HISTORY_MAX_TURNS=12
# DOCVIZ_CHAT_HISTORY_ANSWER_MAX_CHARS=2000

# PINECONE_API_KEY=
# DOCVIZ_VECTOR_STORE=pinecone

# Solo si usas perfil develop (Gemini): mvn -P"!local,develop" package
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# PORT=8080

# Soporte Markdown → S3 (LocalStack) + pgvector (mismo namespace que el repo conectado)
# DOCVIZ_SUPPORT_ENABLED=true
# DOCVIZ_SUPPORT_S3_ENDPOINT=http://127.0.0.1:4566
# Si el backend corre en Docker y el endpoint interno es http://localstack:4566, el front necesita URLs firmadas hacia el host, p. ej.:
# DOCVIZ_SUPPORT_S3_PRESIGN_ENDPOINT=http://127.0.0.1:4566
# DOCVIZ_SUPPORT_S3_REGION=us-east-1
# DOCVIZ_SUPPORT_S3_BUCKET=soporte
# DOCVIZ_WORKSPACE_S3_BORRADOR_BUCKET=borradores
# DOCVIZ_WORKSPACE_S3_WORKAREA_BUCKET=workarea
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
