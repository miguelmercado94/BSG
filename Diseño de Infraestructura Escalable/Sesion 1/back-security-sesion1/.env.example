# =============================================================================
# back-security-sesion1 (BSG) — variables de entorno (API keys, credenciales, URLs)
# =============================================================================
# Copia este archivo a ".env" en este mismo directorio:
#   copy .env.example .env   (Windows)   |   cp .env.example .env   (Linux/macOS)
#
# Carga: DotEnvBootstrap (main) → System properties. No pisa variables ya
# definidas en el SO ni -D... (prioridad: env del sistema > .env > application.yml).
#
# NO subas .env al repositorio (.gitignore).
#
# Docker Compose: el servicio de este módulo puede usar este archivo como env_file.
# El perfil activo en contenedor suele definirse con SPRING_PROFILES_ACTIVE (sustituye
# el valor de la línea de abajo al arrancar con docker compose). Ajusta JWT y el resto aquí.
# =============================================================================

# --- Perfil Spring (dev | qa | pdn) ---
SPRING_PROFILES_ACTIVE=dev

# --- Despliegue (puerto 8081 y contexto /security-auth van fijos en application.yml) ---
BSG_SECURITY_DEPLOYMENT=local

# --- JWT (obligatorio en prod; HS256: secreto ≥ 256 bits; puede ir en Base64) ---
JWT_SECRET=ZmluZHUtZGVmYXVsdC1zZWNyZXQta2V5LWF0LWxlYXN0LTI1Ni1iaXRzLWZvci1oczI1Ng==
JWT_ACCESS_EXPIRATION_SECONDS=300
JWT_REFRESH_EXPIRATION_SECONDS=604800

# --- Base de datos (R2DBC PostgreSQL) — mismo host/puerto que docker-compose: postgres-security ---
SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5433/bsg_security
SPRING_R2DBC_USERNAME=bsg_security
SPRING_R2DBC_PASSWORD=bsg_security
SPRING_SQL_INIT_MODE=always
# Otro Postgres local (ej. findu en 5432):
# SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5432/findu
# SPRING_R2DBC_USERNAME=findu
# SPRING_R2DBC_PASSWORD=findu

# --- Redis (cliente Spring + caché de revocación opcional) ---
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=300ms
SPRING_DATA_REDIS_CONNECT_TIMEOUT=500ms
BSG_SECURITY_REDIS_ENABLED=false
BSG_SECURITY_REDIS_COMMAND_TIMEOUT_MS=300
BSG_SECURITY_REDIS_EVICTION_INTERVAL_MS=3600000
BSG_SECURITY_REDIS_KEY_PREFIX=bsg:revoked:

# --- Actuator / salud ---
MANAGEMENT_HEALTH_REDIS_ENABLED=false

# --- AWS DynamoDB (revocación de tokens; LocalStack o AWS) ---
# Credenciales: el cliente actual usa credenciales estáticas de prueba en código;
# si más adelante usas DefaultCredentialsProvider, define también AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
BSG_SECURITY_AWS_DYNAMODB_ENABLED=false
BSG_SECURITY_AWS_DYNAMODB_ENDPOINT=http://localhost:4566
BSG_SECURITY_AWS_DYNAMODB_REGION=us-east-1
BSG_SECURITY_AWS_DYNAMODB_REVOKED_TOKENS_TABLE=bsg_revoked_tokens
BSG_SECURITY_AWS_DYNAMODB_CREATE_TABLE_IF_NOT_EXISTS=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- Recuperación de contraseña (enlaces en emails) ---
BSG_SECURITY_AUTH_RESET_PASSWORD_BASE_URL=http://localhost:3000/reset-password
BSG_SECURITY_AUTH_RECOVERY_TOKEN_EXPIRY_MINUTES=60

# --- Logging (opcional) ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_BSG_SECURITY=INFO
LOG_LEVEL_BSG_SECURITY_SECURITY_FILTER=INFO
LOG_LEVEL_BSG_SECURITY_USUARIO=INFO
LOG_LEVEL_BSG_SECURITY_RECOVERY=INFO
LOG_LEVEL_BSG_SECURITY_RESET=INFO
LOG_LEVEL_BSG_SECURITY_ADAPTER=INFO
LOG_LEVEL_BSG_SECURITY_CACHE=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_R2DBC=INFO
