# Obligatoria para el cliente.
#
# Recomendado en local (npm run dev): URL directa al backend — la ingesta (POST /vector/ingest)
# puede tardar minutos sin enviar bytes; algunos proxies cortan ese caso. CORS ya permite localhost.
VITE_API_URL=http://127.0.0.1:8080
#
# Alternativa: VITE_API_URL=/api (proxy en vite.config hacia 127.0.0.1:8080)
# - docker-compose (imagen frontend): http://127.0.0.1:8080
# - Railway / prod: https://tu-backend.up.railway.app
